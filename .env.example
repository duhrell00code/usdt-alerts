# Telegram
BOT_TOKEN=your_telegram_bot_token
CHAT_ID=your_chat_id

# Fireblocks
FIREBLOCKS_API_KEY=your_fireblocks_api_key
FIREBLOCKS_PRIVATE_KEY_PATH=/path/to/fireblocks_secret.key

# What to watch — Subscriptions (USDT incoming to fund vaults)
RAI_VAULT_ACCOUNT_ID=0       # rAI subscription vault — Fireblocks vault account ID
ASSET_ID=BNB_BSC_USDT        # Fireblocks asset ID for USDT on BSC
CONTRACT_ADDRESS=            # Optional: USDT BSC contract address as extra filter

RSTR_VAULT_ACCOUNT_ID=       # rSTR subscription vault
RSTR_CONTRACT_ADDRESS=       # Optional: USDT BSC contract address as extra filter

# Redemptions (fund tokens incoming back from investors)
RAI_REDEMPTION_VAULT_ACCOUNT_ID=  # Vault that receives rAI tokens
RAI_REDEMPTION_ASSET_ID=          # Fireblocks asset ID for the rAI token (e.g. RAI_BSC_FW1X)
RAI_REDEMPTION_CONTRACT_ADDRESS=  # Optional: rAI token contract address as extra filter

# Polling
POLL_INTERVAL_SECONDS=3600
STATE_FILE=state.json

# NAV submission monitoring — CONTRACT_CALL from Vault 3 to each fund's NAV contract on BSC
NAV_VAULT_ID=3
RAI_NAV_CONTRACT=0x5D08B15c4241Cc0C147c65a562f0a5f9C5f9ca04
RSTR_NAV_CONTRACT=0x375AFE5eB0924FA507a32D274692828442441E4E
RAIX_NAV_CONTRACT=0x87837F2466cdce52ffDC0793272075e3D2184f6C
