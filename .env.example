# Telegram
BOT_TOKEN=your_telegram_bot_token
CHAT_ID=your_chat_id

# Fireblocks
FIREBLOCKS_API_KEY=your_fireblocks_api_key
FIREBLOCKS_PRIVATE_KEY_PATH=/path/to/fireblocks_secret.key

# What to watch
VAULT_ACCOUNT_ID=0           # Vault account ID from Fireblocks Console (usually 0)
ASSET_ID=BNB_BSC_USDT        # Fireblocks asset ID — find it in Console → Assets
CONTRACT_ADDRESS=            # Optional: BNB chain contract address as extra filter

# Polling
POLL_INTERVAL_SECONDS=3600
STATE_FILE=state.json
